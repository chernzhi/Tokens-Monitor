# 后端环境变量模板 — 复制为 .env 后修改
DATABASE_URL=postgresql+asyncpg://monitor:CHANGE_ME@db:5432/token_monitor
REDIS_URL=redis://redis:6379/0

# 认证配置（必须设置）
COLLECT_API_KEY=CHANGE_ME_GENERATE_A_STRONG_KEY
ADMIN_PASSWORD=CHANGE_ME_GENERATE_A_STRONG_PASSWORD

# CORS 允许域名（逗号分隔，为空时使用默认内网地址）
CORS_ALLOWED_ORIGINS=http://192.168.0.135:3080,http://localhost:3080

# New API 网关配置（可选，如果同时使用 AI 网关）
NEWAPI_BASE_URL=
NEWAPI_ADMIN_TOKEN=

# 汇率
USD_TO_CNY=7.25

# 告警 Webhook（企微/钉钉/飞书，留空则不发告警）
ALERT_WEBHOOK_URL=

# 同步间隔（分钟）
SYNC_INTERVAL_MINUTES=10
